{
  "name": "ieb-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ieb/web dev",
    "build": "pnpm --filter @ieb/web build",
    "preview": "pnpm --filter @ieb/web preview",
    "typecheck": "pnpm --filter @ieb/web typecheck",
    "prepare": "pnpm --filter @ieb/web postinstall",
    "test": "vitest run",
    "test:watch": "vitest --project server",
    "test:server": "vitest run --project server",
    "test:nuxt": "vitest run --project nuxt"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "h3": "1.15.11",
    "node-mock-http": "^1.0.4",
    "vitest": "^4.1.5"
  }
}
