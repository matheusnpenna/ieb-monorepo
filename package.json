{
  "name": "ieb-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ieb/web dev",
    "build": "pnpm --filter @ieb/web build",
    "preview": "pnpm --filter @ieb/web preview",
    "typecheck": "pnpm --filter @ieb/web typecheck",
    "prepare": "pnpm --filter @ieb/web postinstall",
    "test": "pnpm --filter @ieb/web test",
    "test:web:watch": "pnpm --filter @ieb/web test:watch",
    "test:web:server": "pnpm --filter @ieb/web test:server",
    "test:web:nuxt": "pnpm --filter @ieb/web test:nuxt"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.5"
  }
}
